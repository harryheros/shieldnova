  "suspicious_patterns": {
    "_comment": "Regex patterns flagged as MANUAL-REVIEW by audit_existing_rules.py. Edit this list as TLD-abuse landscape shifts — e.g. .gq is no longer free, new abuse TLDs emerge. Each entry is [pattern, reason]. Patterns are applied with re.search() against the lowercased domain.",
    "patterns": [
      ["\\d{6,}",                                       "long numeric string"],
      ["[a-f0-9]{8}-[a-f0-9]{4}",                       "UUID-like"],
      ["[a-z0-9]{32,}\\.",                              "hash-like subdomain"],
